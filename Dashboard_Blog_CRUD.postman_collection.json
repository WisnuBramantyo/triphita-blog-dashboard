					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/blog-posts/{{blog_id}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"blog-posts",
						"{{blog_id}}"
					]
				},
				"description": "Delete a blog post by ID. Uses the ID from collection variables (set automatically when creating a post)."
			},
			"response": []
		},
		{
			"name": "Get Blog Post by ID",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/blog-posts/{{blog_id}}",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"blog-posts",
						"{{blog_id}}"
					]
				},
				"description": "Get a single blog post by its ID. The ID is automatically set when you create a post, or you can manually set it in collection variables."
			},
			"response": []
		},
		{
			"name": "Get All Blog Posts",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/blog-posts",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"blog-posts"
					]
				},
				"description": "Retrieve all blog posts from the dashboard."
			},
			"response": []
		},
		{
			"name": "Get Blog Posts with Filters",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/blog-posts?search=travel&status=published&category=travel",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"blog-posts"
					],
					"query": [
						{
							"key": "search",
							"value": "travel",
							"description": "Search text"
						},
						{
							"key": "status",
							"value": "published",
							"description": "Filter by status"
						},
						{
							"key": "category",
							"value": "travel",
							"description": "Filter by category"
						}
					]
				},
				"description": "Get blog posts with optional filters: search, status, category."
			},
			"response": []
		},
		{
			"name": "Get Dashboard Stats",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/blog-posts/stats",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"blog-posts",
						"stats"
					]
				},
				"description": "Get dashboard statistics (total posts, published posts, drafts, etc.) - same data displayed in the dashboard."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3001",
			"type": "string"
		},
		{
			"key": "blog_id",
			"value": "",
			"type": "string",
			"description": "Automatically set when you create a post"
		}
	]
}

