{
	"info": {
		"_postman_id": "blog-crud-001",
		"name": "Blog CRUD Operations",
		"description": "Postman collection for creating, editing, and deleting blog posts via Laravel API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Create Blog Post",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"if (pm.response.code === 201 || (pm.response.code === 200 && pm.response.json().success)) {",
							"    var jsonData = pm.response.json();",
							"    var data = jsonData.data || jsonData;",
							"    if (data.slug) {",
							"        pm.collectionVariables.set('blog_slug', data.slug);",
							"        pm.collectionVariables.set('blog_id', data.id);",
							"        console.log('✅ Stored slug:', data.slug);",
							"        console.log('✅ Stored ID:', data.id);",
							"    }",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Accept",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"My Amazing Blog Post\",\n  \"content\": \"This is the full content of my blog post. It can contain HTML or plain text.\",\n  \"excerpt\": \"A brief description of the post\",\n  \"category\": \"travel\",\n  \"status\": \"published\",\n  \"featured_image\": \"https://example.com/image.jpg\",\n  \"meta_description\": \"SEO meta description for search engines\",\n  \"tags\": [\"travel\", \"adventure\", \"vacation\"],\n  \"publish_date\": \"2025-01-15T10:00:00.000Z\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/v1/blogs",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"blogs"
					]
				},
				"description": "Create a new blog post. The slug will be automatically generated from the title and stored in collection variables."
			},
			"response": []
		},
